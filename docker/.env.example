# Core
IP=::
PORT=1688
LOGLEVEL=INFO
LOGFILE=/home/py-kms/db/pykms_logserver.log
LOGSIZE=2
CLIENT_COUNT=26
HWID=RANDOM
WEBUI=1

# Optional runtime/container settings
TZ=Europe/Amsterdam
# UID=1000
# GID=100
# DUALSTACK=true

# WebUI auth
# Set a strong password to enable login protection.
PYKMS_WEBUI_PASSWORD=change-me
PYKMS_WEBUI_USERNAME=admin
# Use a long random string in production for stable/secure sessions.
PYKMS_WEBUI_SECRET_KEY=change-me-secret-key

# WebUI session/cookie hardening
PYKMS_WEBUI_COOKIE_SECURE=false
PYKMS_WEBUI_COOKIE_SAMESITE=Lax
PYKMS_WEBUI_SESSION_TTL_SECONDS=43200
PYKMS_WEBUI_LOGIN_RATE_LIMIT_ATTEMPTS=5
PYKMS_WEBUI_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
PYKMS_WEBUI_LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# Blacklist paths (persist these via /home/py-kms/db volume)
PYKMS_BLACKLIST_PATH=/home/py-kms/db/pykms_blacklist.txt
PYKMS_BLACKLIST_STATS_PATH=/home/py-kms/db/pykms_blacklist_stats.json

# Startup source IP backfill
PYKMS_SOURCEIP_BACKFILL_ON_START=1
PYKMS_SOURCEIP_BACKFILL_GLOB=/home/py-kms/db/pykms_logserver.log*
# PYKMS_SOURCEIP_BACKFILL_LOGS=/home/py-kms/db/pykms_logserver.log,/home/py-kms/db/pykms_logserver.log.1

# GeoIP country lookup in clients page
PYKMS_GEOIP_ENABLED=1
PYKMS_GEOIP_PROVIDER=ipapi.co
PYKMS_GEOIP_TIMEOUT_SECONDS=2
PYKMS_GEOIP_CACHE_TTL_SECONDS=604800
PYKMS_GEOIP_ERROR_CACHE_TTL_SECONDS=900
PYKMS_GEOIP_MAX_LOOKUPS_PER_REQUEST=20

# Clients table pagination
PYKMS_WEBUI_CLIENTS_PER_PAGE=100
PYKMS_WEBUI_CLIENTS_MAX_PER_PAGE=500
